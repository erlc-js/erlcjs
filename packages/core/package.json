{
  "name": "@erlcjs/core",
  "description": "ERLC API Wrapper Core",
  "version": "1.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "homepage": "noinkin.github.io/erlcapi",
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/noinkin/erlcapi.git",
    "directory": "packages/core"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "license": "Apache-2.0",
  "scripts": {
    "build": "tsc",
    "lint": "eslint src/**/*.ts",
    "extract": "api-extractor run --local",
    "test": "pnpm tsx --env-file-if-exists=../../.env src/index.test.ts",
    "bench": "pnpm tsx src/index.bench.ts"
  },
  "publishConfig": {
    "access": "public"
  }
}